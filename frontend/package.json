{
  "name": "ykamina-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "admin:create": "node --env-file=.env.local scripts/create-super-admin.mjs",
    "supplier:realflame": "node --env-file=.env.local scripts/import-realflame.mjs",
    "supplier:realflame:stock": "node --env-file=.env.local scripts/import-realflame-stock.mjs",
    "supplier:realflame:sales": "node --env-file=.env.local scripts/import-realflame-sales.mjs",
    "supplier:realflame:specifications": "node --env-file=.env.local scripts/import-realflame-specifications.mjs",
    "supplier:realflame:sync": "npm run supplier:realflame && npm run supplier:realflame:stock && npm run supplier:realflame:sales",
    "supplier:realflame:gallery": "node --env-file=.env.local scripts/import-realflame-gallery.mjs",
    "supplier:realflame:photobank": "node --env-file=.env.local scripts/import-realflame-photobank.mjs",
    "supplier:realflame:compatibilities": "node --env-file=.env.local scripts/import-realflame-compatibilities.mjs",
    "catalog:publish-biofireplaces": "node --env-file=.env.local scripts/publish-biofireplaces.mjs"
  },
  "dependencies": {
    "csv-parse": "5.6.0",
    "jose": "^5.10.0",
    "next": "14.2.33",
    "pg": "8.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/node": "20.17.30",
    "@types/pg": "8.11.10",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.33",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
